---
const { dir, pagination } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
const isRtl = dir === 'rtl';

const leftArrow = '<path d="M17 11H9.41l3.3-3.29a1.004 1.004 0 1 0-1.42-1.42l-5 5a1 1 0 0 0-.21.33 1 1 0 0 0 0 .76 1 1 0 0 0 .21.33l5 5a1.002 1.002 0 0 0 1.639-.325 1 1 0 0 0-.219-1.095L9.41 13H17a1 1 0 0 0 0-2Z"/>';
const rightArrow = '<path d="M17.92 11.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.003 1.003 0 1 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z"/>';
const prevIcon = isRtl ? rightArrow : leftArrow;
const nextIcon = isRtl ? leftArrow : rightArrow;
---

<div class="pagination-links print:hidden" dir={dir}>
  {
    prev && (
      <a
        href={prev.href}
        rel="prev"
        class="font-head transition-all rounded outline-hidden cursor-pointer duration-200 font-medium flex justify-center items-center shadow-md hover:shadow active:shadow-none bg-transparent border-2 border-black hover:translate-y-1 active:translate-y-2 active:translate-x-1 px-4 py-3 text-base no-underline text-foreground"
      >
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="arrow-icon" set:html={prevIcon} />
        <span class="link-content">
          {Astro.locals.t('page.previousLink')}
          <br />
          <span class="link-title">{prev.label}</span>
        </span>
      </a>
    )
  }
  {
    next && (
      <a
        href={next.href}
        rel="next"
        class="font-head transition-all rounded outline-hidden cursor-pointer duration-200 font-medium flex justify-center items-center shadow-md hover:shadow active:shadow-none bg-primary text-primary-foreground border-2 border-black hover:translate-y-1 active:translate-y-2 active:translate-x-1 hover:bg-primary-hover px-4 py-3 text-base no-underline"
      >
        <span class="link-content">
          {Astro.locals.t('page.nextLink')}
          <br />
          <span class="link-title">{next.label}</span>
        </span>
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="arrow-icon" set:html={nextIcon} />
      </a>
    )
  }
</div>

<style>
  .pagination-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 1rem;
  }

  a[rel='next'] {
    text-align: end;
    flex-direction: row-reverse;
  }

  .link-content {
    flex: 1;
  }

  .link-title {
    font-family: var(--font-head);
    font-size: 1.5rem;
    line-height: 1.25;
  }

  .arrow-icon {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
  }
</style>
