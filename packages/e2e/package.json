{
  "name": "@extension/e2e",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "e2e": "bun playwright test",
    "e2e:headed": "bun playwright test --headed",
    "e2e:debug": "bun playwright test --debug",
    "e2e:ui": "bun playwright test --ui",
    "lint": "eslint .",
