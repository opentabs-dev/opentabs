    "format": "prettier . --write --ignore-path ../../.prettierignore",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.19.0",
    "get-port": "^7.1.0"
  }
}
