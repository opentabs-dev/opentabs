{
  "name": "chrome-extension",
  "version": "0.5.0",
  "description": "chrome extension - core settings",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "clean:node_modules": "bunx rimraf node_modules",
    "clean:turbo": "rimraf .turbo",
    "clean": "bun run clean:turbo && bun run clean:node_modules",
    "ready": "tsc -b pre-build.tsconfig.json",
    "build": "vite build && bun build-offscreen.mts && bun build-adapters.mts",
    "dev": "vite build --mode development && bun build-offscreen.mts --mode development && bun build-adapters.mts --mode development",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "bun run lint --fix",
    "prettier": "prettier . --write --ignore-path ../.prettierignore",
    "type-check": "tsc --noEmit",
    "generate-icons": "bun scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@extension/content-script": "workspace:*",
    "@extension/env": "workspace:*",
    "@extension/options": "workspace:*",
    "@extension/shared": "workspace:*",
    "@extension/side-panel": "workspace:*",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@extension/dev-utils": "workspace:*",
    "@extension/hmr": "workspace:*",
    "@extension/tsconfig": "workspace:*",
    "@extension/vite-config": "workspace:*",
    "@laynezh/vite-plugin-lib-assets": "^2.1.3",
    "sharp": "^0.34.5"
  }
}
