{
  "name": "@opentabs-dev/browser-extension",
  "description": "Chrome extension that bridges AI agents to web applications through the user's authenticated browser session",
  "keywords": [
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "ai-agent",
    "browser",
    "chrome-extension",
    "manifest-v3",
    "browser-automation"
  ],
  "version": "0.0.113",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentabs-dev/opentabs.git",
    "directory": "platform/browser-extension"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "manifest.json",
    ".extension-hash",
    "dist/",
    "side-panel/",
    "offscreen/",
    "icons/"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --build",
    "build:bundle": "tsx build-extension.ts",
    "build:side-panel": "tsx build-side-panel.ts && npm run build:tailwind",
    "build:tailwind": "npx @tailwindcss/cli -i src/side-panel/styles.css -o dist/side-panel/styles.css --minify",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@opentabs-dev/shared": "^0.0.113",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/react": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@vitejs/plugin-react": "^5.2.0",
    "esbuild": "^0.28.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^4.62.0",
    "storybook": "^10.2.13",
    "vite": "npm:rolldown-vite@^7.3.1"
  }
}
