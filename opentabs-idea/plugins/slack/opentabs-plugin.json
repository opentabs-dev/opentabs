{
  "name": "opentabs-plugin-slack",
  "version": "0.0.1",
  "displayName": "Slack",
  "description": "OpenTabs plugin for Slack",
  "url_patterns": [
    "*://*.slack.com/*"
  ],
  "tools": [
    {
      "name": "send_message",
      "description": "Send a message to a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to send the message to (e.g., C01234567)"
          },
          "text": {
            "type": "string",
            "description": "Message text to send — supports Slack mrkdwn formatting"
          }
        },
        "required": [
          "channel",
          "text"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the message was sent successfully"
          },
          "channel": {
            "type": "string",
            "description": "Channel ID the message was posted to"
          },
          "ts": {
            "type": "string",
            "description": "Timestamp of the posted message — used as a unique message ID"
          }
        },
        "required": [
          "ok",
          "channel",
          "ts"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "read_messages",
      "description": "Read recent messages from a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to read messages from (e.g., C01234567)"
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of messages to return (default 20, max 1000)"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Message type (e.g., \"message\")"
                },
                "user": {
                  "type": "string",
                  "description": "User ID who sent the message"
                },
                "text": {
                  "type": "string",
                  "description": "Message text content"
                },
                "ts": {
                  "type": "string",
                  "description": "Message timestamp — unique message identifier"
                }
              },
              "required": [
                "type",
                "text",
                "ts"
              ],
              "additionalProperties": false
            },
            "description": "Array of messages in reverse chronological order"
          }
        },
        "required": [
          "ok",
          "messages"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "search_messages",
      "description": "Search for messages across Slack channels",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query string — supports Slack search modifiers (e.g., \"from:@user in:#channel\")"
          },
          "count": {
            "type": "number",
            "description": "Number of results to return (default 20)"
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the search was successful"
          },
          "messages": {
            "type": "object",
            "properties": {
              "total": {
                "type": "number",
                "description": "Total number of matching messages"
              },
              "matches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "channel": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Channel ID where the message was found"
                        },
                        "name": {
                          "type": "string",
                          "description": "Channel name"
                        }
                      },
                      "required": [
                        "id",
                        "name"
                      ],
                      "additionalProperties": false,
                      "description": "Channel information"
                    },
                    "username": {
                      "type": "string",
                      "description": "Username of the message author"
                    },
                    "text": {
                      "type": "string",
                      "description": "Message text content"
                    },
                    "ts": {
                      "type": "string",
                      "description": "Message timestamp"
                    },
                    "permalink": {
                      "type": "string",
                      "description": "Permanent link to the message"
                    }
                  },
                  "required": [
                    "channel",
                    "username",
                    "text",
                    "ts",
                    "permalink"
                  ],
                  "additionalProperties": false
                },
                "description": "Array of matching messages"
              }
            },
            "required": [
              "total",
              "matches"
            ],
            "additionalProperties": false,
            "description": "Search results"
          }
        },
        "required": [
          "ok",
          "messages"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "list_channels",
      "description": "List channels in the Slack workspace",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "description": "Maximum number of channels to return (default 100, max 1000)"
          },
          "types": {
            "type": "string",
            "description": "Comma-separated channel types to include (default \"public_channel\" — options: public_channel, private_channel, mpim, im)"
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Channel ID (e.g., C01234567)"
                },
                "name": {
                  "type": "string",
                  "description": "Channel name without the # prefix"
                },
                "is_channel": {
                  "type": "boolean",
                  "description": "Whether this is a public channel"
                },
                "is_private": {
                  "type": "boolean",
                  "description": "Whether this is a private channel"
                },
                "num_members": {
                  "type": "number",
                  "description": "Number of members in the channel"
                },
                "topic": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "description": "Channel topic text"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": false,
                  "description": "Channel topic"
                },
                "purpose": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "description": "Channel purpose text"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": false,
                  "description": "Channel purpose"
                }
              },
              "required": [
                "id",
                "name",
                "is_channel",
                "is_private",
                "num_members",
                "topic",
                "purpose"
              ],
              "additionalProperties": false
            },
            "description": "Array of channels matching the filter criteria"
          }
        },
        "required": [
          "ok",
          "channels"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_channel_info",
      "description": "Get detailed information about a Slack channel including topic, purpose, and member count",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to get info for (e.g., C01234567)"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "channel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Channel ID"
              },
              "name": {
                "type": "string",
                "description": "Channel name without the # prefix"
              },
              "is_channel": {
                "type": "boolean",
                "description": "Whether this is a public channel"
              },
              "is_private": {
                "type": "boolean",
                "description": "Whether this is a private channel"
              },
              "num_members": {
                "type": "number",
                "description": "Number of members in the channel"
              },
              "topic": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "description": "Channel topic text"
                  }
                },
                "required": [
                  "value"
                ],
                "additionalProperties": false,
                "description": "Channel topic"
              },
              "purpose": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "description": "Channel purpose text"
                  }
                },
                "required": [
                  "value"
                ],
                "additionalProperties": false,
                "description": "Channel purpose"
              }
            },
            "required": [
              "id",
              "name",
              "is_channel",
              "is_private",
              "num_members",
              "topic",
              "purpose"
            ],
            "additionalProperties": false,
            "description": "Detailed channel information"
          }
        },
        "required": [
          "ok",
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "create_channel",
      "description": "Create a new public or private Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the new channel — must be lowercase, no spaces, max 80 chars (e.g., \"project-updates\")"
          },
          "is_private": {
            "type": "boolean",
            "description": "Whether to create a private channel (default false — creates public channel)"
          },
          "topic": {
            "type": "string",
            "description": "Initial topic for the channel"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the channel was created successfully"
          },
          "channel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "ID of the newly created channel"
              },
              "name": {
                "type": "string",
                "description": "Name of the created channel"
              },
              "is_private": {
                "type": "boolean",
                "description": "Whether the channel is private"
              }
            },
            "required": [
              "id",
              "name",
              "is_private"
            ],
            "additionalProperties": false,
            "description": "The newly created channel"
          }
        },
        "required": [
          "ok",
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_channel_topic",
      "description": "Set the topic of a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to set the topic for (e.g., C01234567)"
          },
          "topic": {
            "type": "string",
            "description": "New topic text for the channel (max 250 chars)"
          }
        },
        "required": [
          "channel",
          "topic"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the topic was set successfully"
          },
          "topic": {
            "type": "string",
            "description": "The topic that was set"
          }
        },
        "required": [
          "ok",
          "topic"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_channel_purpose",
      "description": "Set the purpose of a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to set the purpose for (e.g., C01234567)"
          },
          "purpose": {
            "type": "string",
            "description": "New purpose text for the channel (max 250 chars)"
          }
        },
        "required": [
          "channel",
          "purpose"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the purpose was set successfully"
          },
          "purpose": {
            "type": "string",
            "description": "The purpose that was set"
          }
        },
        "required": [
          "ok",
          "purpose"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "invite_to_channel",
      "description": "Invite a user to a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to invite the user to (e.g., C01234567)"
          },
          "users": {
            "type": "string",
            "description": "User ID to invite (e.g., U01234567)"
          }
        },
        "required": [
          "channel",
          "users"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the invitation was successful"
          },
          "channel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Channel ID the user was invited to"
              },
              "name": {
                "type": "string",
                "description": "Channel name"
              }
            },
            "required": [
              "id",
              "name"
            ],
            "additionalProperties": false,
            "description": "The channel the user was invited to"
          }
        },
        "required": [
          "ok",
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "list_members",
      "description": "List members of a Slack channel with optional pagination",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID to list members for (e.g., C01234567)"
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of members to return (default 100, max 1000)"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor from a previous response for fetching the next page"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "members": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "User ID"
            },
            "description": "Array of user IDs who are members of the channel"
          },
          "response_metadata": {
            "type": "object",
            "properties": {
              "next_cursor": {
                "type": "string",
                "description": "Cursor for the next page of results — empty string if no more pages"
              }
            },
            "required": [
              "next_cursor"
            ],
            "additionalProperties": false,
            "description": "Pagination metadata"
          }
        },
        "required": [
          "ok",
          "members"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_user_profile",
      "description": "Retrieve a Slack user's profile information by user ID",
      "input_schema": {
        "type": "object",
        "properties": {
          "user": {
            "type": "string",
            "description": "User ID to retrieve the profile for (e.g., U01234567)"
          }
        },
        "required": [
          "user"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
