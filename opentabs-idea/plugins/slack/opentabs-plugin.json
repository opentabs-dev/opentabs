          },
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "User ID"
              },
              "name": {
                "type": "string",
                "description": "Username (handle)"
              },
              "real_name": {
                "type": "string",
                "description": "Full display name"
              },
              "profile": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Job title"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number"
                  },
                  "email": {
                    "type": "string",
                    "description": "Email address"
                  },
                  "status_text": {
                    "type": "string",
                    "description": "Custom status text"
                  },
                  "status_emoji": {
                    "type": "string",
                    "description": "Custom status emoji"
                  },
                  "image_72": {
                    "type": "string",
                    "description": "URL to 72x72 profile image"
                  }
                },
                "required": [
                  "title",
                  "phone",
                  "email",
                  "status_text",
                  "status_emoji",
                  "image_72"
                ],
                "additionalProperties": false,
                "description": "Detailed profile information"
              },
              "is_admin": {
                "type": "boolean",
                "description": "Whether the user is a workspace admin"
              },
              "is_bot": {
                "type": "boolean",
                "description": "Whether the user is a bot"
              },
              "tz": {
                "type": "string",
                "description": "Timezone identifier (e.g., America/Los_Angeles)"
              }
            },
            "required": [
              "id",
              "name",
              "real_name",
              "profile",
              "is_admin",
              "is_bot",
              "tz"
            ],
            "additionalProperties": false,
            "description": "User profile data"
          }
        },
        "required": [
          "ok",
          "user"
        ],
        "additionalProperties": false
      }
    },
    {
