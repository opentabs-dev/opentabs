{
  "name": "@opentabs/browser-extension",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "build:side-panel": "bun run build-side-panel.ts && bun run build:tailwind",
