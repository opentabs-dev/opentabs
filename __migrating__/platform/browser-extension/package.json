{
  "name": "@opentabs/browser-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/background/index.d.ts",
      "default": "./dist/background/index.js"
    },
    "./offscreen": {
      "types": "./dist/offscreen/offscreen.d.ts",
      "default": "./dist/offscreen/offscreen.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:extension": "bun run build.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opentabs/core": "workspace:*",
    "@opentabs/plugin-loader": "workspace:*",
    "@opentabs/plugin-slack": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.318",
    "typescript": "^5.9.3"
  }
}
