{
  "$schema": "https://opentabs.dev/schemas/plugin-v1.json",
  "name": "{{pluginName}}",
  "displayName": "{{displayName}}",
  "version": "0.1.0",
  "description": "{{description}}",
  "author": "{{author}}",
  "license": "MIT",

  "adapter": {
    "entry": "./dist/adapter.js",
    "domains": {
      "production": "{{domain}}"
    },
    "urlPatterns": {
      "production": ["*://{{domain}}/*"]
    }
  },

  "service": {
    "timeout": 30000,
    "environments": ["production"],
    "authErrorPatterns": ["401", "Unauthorized", "403", "Forbidden"],
    "healthCheck": {
      "method": "{{pluginName}}.api",
      "params": {
        "endpoint": "/api/health",
        "method": "GET"
      }
    }
  },

  "tools": {
    "entry": "./dist/tools/index.js",
    "categories": [
      {
        "id": "general",
        "label": "General"
      }
    ]
  },

  "permissions": {
    "network": ["{{domain}}"],
    "storage": false,
    "nativeApis": []
  },

  "keywords": ["{{pluginName}}"]
}
