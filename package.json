{
  "name": "opentabs",
  "version": "0.5.0",
  "description": "Turns tabs into tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nichochar/opentabs"
  },
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "chrome-extension",
    "pages/*",
    "packages/*"
  ],
  "scripts": {
    "clean:bundle": "rimraf dist && turbo clean:bundle",
    "clean:node_modules": "bunx rimraf node_modules && turbo clean:node_modules",
    "clean:turbo": "rimraf .turbo && turbo clean:turbo",
    "clean": "bun run clean:bundle && bun run clean:turbo && bun run clean:node_modules",
    "clean:install": "bun run clean:node_modules && bun install --frozen-lockfile",
    "type-check": "turbo type-check",
    "base-build": "bun run clean:bundle && turbo build",
    "build": "bun run set-global-env && bun run base-build",
    "build:firefox": "bun run set-global-env CLI_CEB_FIREFOX=true && bun run base-build",
    "base-dev": "bun run clean:bundle && turbo ready && turbo watch dev",
    "dev": "bun run set-global-env CLI_CEB_DEV=true && bun run base-dev",
    "dev:firefox": "bun run set-global-env CLI_CEB_DEV=true CLI_CEB_FIREFOX=true && bun run base-dev",
    "zip": "bun run build && bun run --filter @extension/zipper zip",
    "zip:firefox": "bun run build:firefox && bun run --filter @extension/zipper zip",
    "e2e": "bun run zip && turbo e2e",
    "e2e:firefox": "bun run zip:firefox && turbo e2e",
    "knip": "knip",
    "lint": "turbo lint --continue && bun run knip",
    "lint:fix": "turbo lint:fix --continue",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "prepare": "husky",
    "update-version": "bash bash-scripts/update_version.sh",
    "copy-env": "bash bash-scripts/copy_env.sh",
    "set-global-env": "bash bash-scripts/set_global_env.sh",
    "postinstall": "bun run copy-env"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.2.14",
    "@types/chrome": "^0.1.36",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^10.1.0",
    "deepmerge": "^4.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.3",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.8.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "knip": {
    "ignoreDependencies": [
      "tailwindcss",
      "tw-animate-css"
    ],
    "exclude": [
      "files"
    ]
  }
}
